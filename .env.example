# Скопируйте этот файл в .env и подставьте свои значения.
# .env не коммитится в репозиторий (см. .gitignore).

# Токен HuggingFace для pyannote-audio (диаризация).
# Получить: https://huggingface.co/settings/tokens
# Дополнительно принять условия модели: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here
