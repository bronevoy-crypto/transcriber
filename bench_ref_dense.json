[
  {
    "speaker": "A",
    "text": "Смотри, я нашёл баг в коде.",
    "start": 0.0,
    "end": 2.013
  },
  {
    "speaker": "B",
    "text": "Какой именно?",
    "start": 2.213,
    "end": 3.075
  },
  {
    "speaker": "A",
    "text": "Индекс выходит за границы массива при пустом вводе.",
    "start": 3.275,
    "end": 6.838
  },
  {
    "speaker": "B",
    "text": "Понятно, это в функции обработки?",
    "start": 7.038,
    "end": 9.275
  },
  {
    "speaker": "A",
    "text": "Да, в строке сорок два.",
    "start": 9.775,
    "end": 11.6
  },
  {
    "speaker": "B",
    "text": "Я посмотрю сейчас.",
    "start": 11.8,
    "end": 13.187
  },
  {
    "speaker": "A",
    "text": "Нужно добавить проверку на длину.",
    "start": 13.387,
    "end": 15.675
  },
  {
    "speaker": "B",
    "text": "Согласна. Или исключение поймать.",
    "start": 15.875,
    "end": 18.475
  },
  {
    "speaker": "A",
    "text": "Исключение хуже — клиент увидит ошибку.",
    "start": 18.975,
    "end": 22.087
  },
  {
    "speaker": "B",
    "text": "Верно. Проверку лучше.",
    "start": 22.287,
    "end": 24.2
  },
  {
    "speaker": "A",
    "text": "Сделай пулл реквест, я ревью сделаю.",
    "start": 24.4,
    "end": 27.175
  },
  {
    "speaker": "B",
    "text": "Хорошо, через час готово будет.",
    "start": 27.375,
    "end": 29.475
  },
  {
    "speaker": "A",
    "text": "Отлично, напиши в чат когда готово.",
    "start": 29.975,
    "end": 32.562
  },
  {
    "speaker": "B",
    "text": "Договорились.",
    "start": 32.763,
    "end": 33.738
  }
]